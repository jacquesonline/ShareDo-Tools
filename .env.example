# ──────────────────────────────────────────────
# ShareDo Tools - Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Usage: npm start [-- <initial-environment>]
# Example: npm start -- vnext
#
# All environments with a CLIENT_ID and CLIENT_SECRET will appear
# in the dashboard dropdown. The startup argument is optional and
# sets the initial selection (defaults to the first found).
#
# Optional per-environment fields:
#   {ENV}_LABEL          Display name in the dropdown (defaults to ENV in uppercase)
#   {ENV}_API_HOST       Override the derived API host
#   {ENV}_IDENTITY_HOST  Override the derived identity host
#   {ENV}_COOKIE_USERNAME  Username sent as part of the Automatic Authorisation flow
#   {ENV}_COOKIE_PASSWORD  Password sent as part of the AutoAuth flow for forms based login
#
# Settings marked (Options) can also be changed at runtime via the
# Options page. Runtime changes are saved to cache/settings.json
# and override the .env values on next startup.
# ──────────────────────────────────────────────

## ─── vnext ───
VNEXT_CLIENT_ID=
VNEXT_CLIENT_SECRET=
VNEXT_LABEL=vNext
# Auto-authentication: local forms-based account used to acquire a session cookie on startup.
# Leave blank to disable automatic cookie acquisition for this environment.
VNEXT_COOKIE_USERNAME=
VNEXT_COOKIE_PASSWORD=

## ─── uat ───
UAT_CLIENT_ID=
UAT_CLIENT_SECRET=
UAT_LABEL=UAT
# UAT_COOKIE_USERNAME=
# UAT_COOKIE_PASSWORD=

## ─── preprod ───
PREPROD_CLIENT_ID=
PREPROD_CLIENT_SECRET=
PREPROD_LABEL=Pre-Prod
# PREPROD_COOKIE_USERNAME=
# PREPROD_COOKIE_PASSWORD=

## ─── prod ───
PROD_CLIENT_ID=
PROD_CLIENT_SECRET=
PROD_LABEL=Production
# PROD_API_HOST=mauriceblackburn.sharedo.tech
# PROD_IDENTITY_HOST=mb-prod-identity.sharedo.tech
# Automatic cookie acquisition is not available for Production.
# Production uses Azure AD SSO exclusively -- no forms-based accounts are configured.

## ─── Server ───
PORT=3000

## ─── Multi-User Mode ───
# Set to true when hosting for the team. Enables user registration,
# session management, and admin-gated server settings.
# When false (default), the app behaves as a single-user local tool
# with no login required.
# MULTI_USER=false

# Required when MULTI_USER=true. Grants admin access to server-level
# settings, cookie management, and future admin dashboard features.
# Share this key only with designated administrators.
# ADMIN_KEY=

# Session cookie lifetime in days. Users re-register after expiry.
# Preferences and settings persist across re-registration.
# SESSION_EXPIRY_DAYS=30

## ─── Monitor (Options) ───
# Backlogs above this value show as red / critical. Alert duration timer starts here.
BACKLOG_THRESHOLD=250

# Minimum seconds a condition must persist before a desktop notification fires.
# Applied per-condition when "Use Alert Duration Threshold" is enabled in Options.
# Set to 0 for immediate notifications on threshold breach.
ALERT_DURATION_THRESHOLD=60

## ─── Notifications: Teams Webhook ───
# Sends alerts to a Microsoft Teams channel via an incoming webhook.
# Only one running instance of ShareDo Tools should have this enabled.
# Future: will become an admin-level setting once multi-user hosting is supported.
#
# To configure:
#   1. In Teams, go to the target channel > Connectors > Incoming Webhook
#   2. Create a webhook and copy the URL
#   3. Set TEAMS_WEBHOOK_ENABLED=true and paste the URL below
#
# TEAMS_WEBHOOK_ENABLED=false
# TEAMS_WEBHOOK_URL=

## ─── WAILA (Options) ───
# Milliseconds between individual workflow plan fetches during index build.
# Lower = faster build, higher = less API load.
# WAILA_FETCH_DELAY=100

## ─── Logging ───
# Log output is grouped by category, each independently toggleable.
# All categories default to true. Set to false to suppress.
#
# LOG_ENV=true           # Environment switch events
# LOG_SETTINGS=true      # Settings load/save/update
# LOG_HEALTH=true        # Health monitor lifecycle
# LOG_ALERT=true         # Alert dispatch (desktop + Teams)
# LOG_TEAMS=true         # Teams webhook delivery details
# LOG_COOKIE=true        # Cookie set/clear/refresh, acquisition outcomes
# LOG_AUTOAUTH=true      # OIDC acquisition step-by-step detail (noisy)
# LOG_API=true           # ShareDo API errors (4xx/5xx)
# LOG_METRICS=true       # Metrics file pruning
# LOG_WAILA=true         # WAILA index build progress
# LOG_WTINDEX=true       # Work type config index build progress

# Sub-filter: when LOG_API is true, also show 401 responses?
# 401s are frequent during the auth cascade and usually not actionable.
LOG_401=false

## ─── Metrics ───
# Maximum file size per metric file in MB. Files are pruned when they exceed this.
# METRICS_MAX_MB=50

## ─── UX Monitoring ─── #
# Alert toggles (all default to true)
# UX_ALERTS_PROBES=true
# UX_ALERTS_PAGES=true
# UX_ALERTS_SESSION=true

# API Probe thresholds (ms)
# UX_PROBE_THRESHOLD_WARN=3000
# UX_PROBE_THRESHOLD_CRIT=5000

# Web Vital thresholds (ms) -- used for both alerts and UX page colour ratings
# Google's recommended boundaries are used as defaults
# UX_VITALS_FCP_WARN=1800
# UX_VITALS_FCP_CRIT=3000
# UX_VITALS_LCP_WARN=2500
# UX_VITALS_LCP_CRIT=4000
# UX_VITALS_TTI_WARN=3800
# UX_VITALS_TTI_CRIT=7300

# Page check targets (comma-separated paths, default: /,/admin)
# Paths containing {guid} are substituted with UX_WORK_ITEM_ID
# UX_PAGE_TARGETS=/,/admin,/sharedo/{guid}

# Work item GUID for probes and page checks (empty = skip work item monitoring)
# UX_WORK_ITEM_ID=

## ─── Test Environment ───
# Enables a synthetic "Test Env" entry in the environment dropdown for
# notification testing without affecting real environments.
# Accessible at /debug/mock when enabled.
# MOCK_ENV_ENABLED=false
